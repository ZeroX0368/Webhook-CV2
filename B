import json
import time
import uuid
import re
import cloudscraper
from flask import Flask, request, jsonify

app = Flask(__name__)

GRAPHQL = "https://publisher.linkvertise.com/graphql"

# Các mẫu truy vấn GraphQL từ mã nguồn của bạn
GQL_GET_CONTENT = """
query getContent($identifier: PublicLinkIdentificationInput!, $action_id: String) {
  getContent(input: $identifier, action_id: $action_id) {
    ... on ContentAccessTaskSet {
      __typename
      tasks {
        __typename
        id
        ... on WaitTask    { id status }
        ... on AdTask      { id status }
      }
    }
    ... on DetailPageTargetData {
      __typename
      type
      url
      paste
    }
  }
}
"""

GQL_START_TASK = """
mutation startTask($identifier: PublicLinkIdentificationInput!, $task_id: String!, $task_args: TaskArgument) {
  startTask(input: $identifier, task_id: $task_id, task_args: $task_args) { id status }
}
"""

GQL_COMPLETE_TASK = """
mutation completeTask($identifier: PublicLinkIdentificationInput!, $task_id: String!, $task_args: TaskArgument) {
  completeTask(input: $identifier, task_id: $task_id, task_args: $task_args) { id status }
}
"""

def extract_data(url):
    """Trích xuất user_id và slug từ linkvertise URL"""
    match = re.search(r"linkvertise\.com/(\d+)/([\w-]+)", url)
    if match:
        return match.group(1), match.group(2)
    return None, None

def gql_call(session, query, variables, headers):
    resp = session.post(GRAPHQL, json={"query": query, "variables": variables}, headers=headers, timeout=15)
    return resp.json()

def bypass_linkvertise(target_url):
    start_time = time.time()
    user_id, slug = extract_data(target_url)
    
    if not user_id or not slug:
        return {"success": False, "error": "Invalid Linkvertise URL format"}

    identifier = {"userIdAndUrl": {"user_id": user_id, "url": slug}}
    session = cloudscraper.create_scraper(browser={"browser": "chrome", "platform": "windows", "mobile": False})
    
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36",
        "Referer": target_url,
        "Origin": "https://linkvertise.com",
        "Content-Type": "application/json",
    }

    # Chạy tối đa 10 vòng lặp để giải quyết các task
    for _ in range(10):
        try:
            resp = gql_call(session, GQL_GET_CONTENT, {"identifier": identifier, "action_id": str(uuid.uuid4())}, headers)
            data = resp.get("data", {}).get("getContent", {})
            
            # Nếu đã lấy được URL đích hoặc nội dung Paste
            if data.get("__typename") == "DetailPageTargetData":
                final_url = data.get("paste") or data.get("url")
                return {
                    "success": True, 
                    "result": final_url, 
                    "type": data.get("type"),
                    "time_ms": int((time.time() - start_time) * 1000)
                }

            tasks = data.get("tasks", [])
            active_task = next((t for t in tasks if t.get("status") in ("OPEN", "IN_PROGRESS")), None)
            
            if active_task:
                t_id = active_task["id"]
                # Giả lập quy trình: Start -> Wait -> Complete
                gql_call(session, GQL_START_TASK, {"identifier": identifier, "task_id": t_id, "task_args": {"action_id": str(uuid.uuid4())}}, headers)
                time.sleep(1) 
                gql_call(session, GQL_COMPLETE_TASK, {"identifier": identifier, "task_id": t_id, "task_args": {"action_id": str(uuid.uuid4())}}, headers)
            else:
                break
                
            time.sleep(0.5)
        except Exception as e:
            return {"success": False, "error": str(e)}

    return {"success": False, "error": "Could not bypass after multiple attempts"}

@app.route('/api/link', methods=['GET'])
def api_handler():
    url = request.args.get('url')
    if not url:
        return jsonify({"success": False, "error": "URL parameter is required"}), 400
    
    result = bypass_linkvertise(url)
    return jsonify(result)

if __name__ == "__main__":
    print("API Server đang chạy tại http://localhost:5000/api/link?url=...")
    app.run(host='0.0.0.0', port=5000)
