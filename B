import json
import time
import uuid
import re
import cloudscraper
from flask import Flask, request, jsonify

app = Flask(__name__)

# --- Cấu hình Linkvertise ---
GRAPHQL = "https://publisher.linkvertise.com/graphql"
GQL_GET_CONTENT = """query getContent($identifier: PublicLinkIdentificationInput!, $action_id: String) { getContent(input: $identifier, action_id: $action_id) { ... on ContentAccessTaskSet { __typename tasks { __typename id ... on WaitTask { id status } ... on AdTask { id status } } } ... on DetailPageTargetData { __typename type url paste } } }"""
GQL_START_TASK = """mutation startTask($identifier: PublicLinkIdentificationInput!, $task_id: String!, $task_args: TaskArgument) { startTask(input: $identifier, task_id: $task_id, task_args: $task_args) { id status } }"""
GQL_COMPLETE_TASK = """mutation completeTask($identifier: PublicLinkIdentificationInput!, $task_id: String!, $task_args: TaskArgument) { completeTask(input: $identifier, task_id: $task_id, task_args: $task_args) { id status } }"""

def extract_lv_data(url):
    match = re.search(r"linkvertise\.com/(\d+)/([\w-]+)", url)
    return (match.group(1), match.group(2)) if match else (None, None)

def bypass_linkvertise(target_url, session):
    user_id, slug = extract_lv_data(target_url)
    if not user_id: return {"Status": "Error", "result": "Invalid Linkvertise URL"}
    
    identifier = {"userIdAndUrl": {"user_id": user_id, "url": slug}}
    headers = {"User-Agent": "Mozilla/5.0", "Referer": target_url, "Origin": "https://linkvertise.com", "Content-Type": "application/json"}

    for _ in range(10):
        try:
            resp = session.post(GRAPHQL, json={"query": GQL_GET_CONTENT, "variables": {"identifier": identifier, "action_id": str(uuid.uuid4())}}, headers=headers).json()
            data = resp.get("data", {}).get("getContent", {})
            if data.get("__typename") == "DetailPageTargetData":
                return {"Status": "Success", "result": data.get("paste") or data.get("url")}
            
            tasks = data.get("tasks", [])
            task = next((t for t in tasks if t.get("status") in ("OPEN", "IN_PROGRESS")), None)
            if task:
                t_id = task["id"]
                session.post(GRAPHQL, json={"query": GQL_START_TASK, "variables": {"identifier": identifier, "task_id": t_id, "task_args": {"action_id": str(uuid.uuid4())}}}, headers=headers)
                time.sleep(1.5) # Giả lập chờ
                session.post(GRAPHQL, json={"query": GQL_COMPLETE_TASK, "variables": {"identifier": identifier, "task_id": t_id, "task_args": {"action_id": str(uuid.uuid4())}}}, headers=headers)
            else: break
        except: break
    return {"Status": "Error", "result": "Bypass Linkvertise failed"}

# --- Cấu hình LootLabs (Tự viết không qua API trung gian) ---
def bypass_lootlabs(target_url, session):
    try:
        # 1. Lấy loot_id từ URL
        loot_id = target_url.split('/')[-1]
        client_id = str(uuid.uuid4())
        
        headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
            "Referer": "https://loot-link.com/",
            "Origin": "https://loot-link.com"
        }

        # 2. Bước 1: Khởi tạo session với LootLabs
        init_url = f"https://api.lootlabs.com/v1/links/{loot_id}/click?client_id={client_id}"
        session.get(init_url, headers=headers)
        
        # 3. Bước 2: Giả lập chờ quảng cáo (LootLabs thường yêu cầu 10-15s)
        # Để bypass nhanh, ta thử gọi trực tiếp nhưng vẫn nên nghỉ một chút
        time.sleep(2)
        
        # 4. Bước 3: Lấy link cuối
        res = session.get(f"https://api.lootlabs.com/v1/links/{loot_id}/target?client_id={client_id}", headers=headers)
        data = res.json()
        
        if "target" in data:
            return {"Status": "Success", "result": data["target"]}
        elif "message" in data:
            return {"Status": "Error", "result": data["message"]}
        
        return {"Status": "Error", "result": "LootLabs bypass failed"}
    except Exception as e:
        return {"Status": "Error", "result": str(e)}

@app.route('/api/link', methods=['GET'])
def api_handler():
    req_start_time = time.time()
    url = request.args.get('url')
    
    if not url:
        return jsonify({"Status": "Error", "result": "URL is required", "duration": "0.00s"}), 400

    session = cloudscraper.create_scraper(browser={'browser': 'chrome', 'platform': 'windows', 'mobile': False})
    
    # Router nhận diện link
    if "linkvertise.com" in url:
        response_data = bypass_linkvertise(url, session)
    elif any(x in url for x in ["loot-link", "loot-links", "lootlabs"]):
        response_data = bypass_lootlabs(url, session)
    else:
        response_data = {"Status": "Error", "result": "Unsupported domain"}

    # Tính toán duration
    duration_val = f"{(time.time() - req_start_time):.2f}s"
    response_data["duration"] = duration_val
    
    return jsonify(response_data)

if __name__ == "__main__":
    app.run(host='0.0.0.0', port=5000)
